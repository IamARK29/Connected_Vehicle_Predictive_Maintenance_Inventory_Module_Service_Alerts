# Large synthetic telemetry files (regenerate via POST /synthetic/generate)
# Each file is ~160MB — exceeds GitHub 100MB limit
data/synthetic/telemetry_*.csv
data/synthetic/trips.csv

# Runtime logs
*.log
api_stdout.log
api_stderr.log
dealer_portal/vite_stdout.log
dealer_portal/vite_stderr.log

# Scratchpad / temp
scratchpad/
*.bak

# MLflow experiment tracking
mlruns/

# Generated feature cache (rebuild via feature_refresh_job)
data/feature_store/

# Vite production build output
dealer_portal/public/

# Playwright — generated test artefacts (not source)
dealer_portal/playwright-report/
dealer_portal/test-results/
dealer_portal/e2e/.auth/

# Word temp/lock files
~$*.docx

# Doc-generation intermediate files (base64 blobs, not needed in repo)
docs/diagrams/b64*.txt
docs/diagrams/b64.json
docs/diagrams/b64_web.json
