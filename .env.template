# InfluxDB (time-series telemetry store)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=autopredict
INFLUXDB_BUCKET=telemetry

# PostgreSQL (relational data)
POSTGRES_URL=postgresql://autopredict:autopredict@localhost:5432/autopredict_db
POSTGRES_ASYNC_URL=postgresql+asyncpg://autopredict:autopredict@localhost:5432/autopredict_db

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=vehicle.telemetry
KAFKA_ALERTS_TOPIC=vehicle.alerts

# Redis
REDIS_URL=redis://localhost:6379/0

# AI / LLM
ANTHROPIC_API_KEY=your-anthropic-api-key

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# MQTT (TBox broker)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Push Notifications
FCM_SERVER_KEY=your-fcm-server-key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=alerts@autopredict.io

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
