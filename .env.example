# AutoPredict — Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://autopredict:autopredict@localhost:5432/autopredict_db
DATABASE_URL=postgresql://autopredict:autopredict@localhost:5432/autopredict_db

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=autopredict-dev-token
INFLUXDB_ORG=autopredict
INFLUXDB_BUCKET=telemetry

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a cryptographically random 32+ char string in production.
SECRET_KEY=change-me-in-production-use-32-char-random-string

# JWT token expiry in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MQTT / TBox Ingestion (Mode A) ───────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=autopredict/telemetry
# Optional MQTT auth
MQTT_USERNAME=
MQTT_PASSWORD=
# TLS (true/false)
MQTT_TLS=false

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_TELEMETRY=tbox.telemetry
KAFKA_CONSUMER_GROUP=autopredict-consumer

# ── AI Agent ─────────────────────────────────────────────────────────────────
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Agent model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=autopredict

# ── Data Directories ─────────────────────────────────────────────────────────
DATA_DIR=data/synthetic
MODEL_DIR=models/saved

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development only.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT=200/minute

# ── Alerts / Notifications ───────────────────────────────────────────────────
# Alert cooldown in seconds (default: 86400 = 24 hours)
ALERT_COOLDOWN_SECONDS=86400

# Optional: SMS/Email notification endpoints
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ── Dealer Portal ────────────────────────────────────────────────────────────
# Set in dealer_portal/.env (or via VITE_ prefix for Vite)
# VITE_API_BASE_URL=http://localhost:8000
# VITE_DEALER_CODE=DL001

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
